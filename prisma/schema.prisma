generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  image        String?
  passwordHash String?
  bio          String?
  role         String       @default("member")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  accounts     Account[]
  scenarios    Scenario[]
  sessions     Session[]
  solutions    Solution[]
  technologies Technology[]
  votes        Vote[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Technology {
  id          String               @id @default(cuid())
  name        String               @unique
  slug        String               @unique
  category    String
  icon        String?
  createdAt   DateTime             @default(now())
  createdById String?
  scenarios   ScenarioTechnology[]
  creator     User?                @relation(fields: [createdById], references: [id])

  @@index([category])
  @@index([slug])
}

model Scenario {
  id           String               @id @default(cuid())
  title        String
  summary      String
  content      String
  difficulty   String               @default("intermediate")
  status       String               @default("open")
  views        Int                  @default(0)
  authorId     String
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  attachments  String?
  author       User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  technologies ScenarioTechnology[]
  solutions    Solution[]
  votes        Vote[]

  @@index([authorId])
  @@index([difficulty])
  @@index([status])
  @@index([createdAt])
}

model ScenarioTechnology {
  scenarioId   String
  technologyId String
  technology   Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)
  scenario     Scenario   @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@id([scenarioId, technologyId])
}

model Solution {
  id          String   @id @default(cuid())
  scenarioId  String
  authorId    String
  content     String
  codeSnippet String?
  language    String?
  isAccepted  Boolean  @default(false)
  upvotes     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  scenario    Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  votes       Vote[]

  @@index([scenarioId])
  @@index([authorId])
}

model Vote {
  id         String    @id @default(cuid())
  userId     String
  value      Int
  createdAt  DateTime  @default(now())
  scenarioId String?
  solutionId String?
  solution   Solution? @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  scenario   Scenario? @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scenarioId])
  @@unique([userId, solutionId])
  @@index([scenarioId])
  @@index([solutionId])
}
