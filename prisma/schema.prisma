// Prisma schema for ScenarioForge - tech scenario sharing platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── NextAuth models ───────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  passwordHash  String?
  bio           String?
  role          String    @default("member")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  scenarios     Scenario[]
  solutions     Solution[]
  votes         Vote[]
  technologies  Technology[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domain models ─────────────────────────────────────────────────

model Technology {
  id         String   @id @default(cuid())
  name       String   @unique
  slug       String   @unique
  category   String
  icon       String?
  createdAt  DateTime @default(now())
  createdById String?

  creator    User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  scenarios  ScenarioTechnology[]

  @@index([category])
  @@index([slug])
}

model Scenario {
  id          String   @id @default(cuid())
  title       String
  summary     String
  content     String
  difficulty  String   @default("intermediate") // beginner | intermediate | advanced | expert
  status      String   @default("open") // open | solved | archived
  views       Int      @default(0)
  // JSON string array of { type:'image'|'file', name, mime, size, data }
  // stored as text so attachments travel with the scenario (portable sharing).
  attachments String?
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  technologies ScenarioTechnology[]
  solutions   Solution[]
  votes       Vote[]

  @@index([authorId])
  @@index([difficulty])
  @@index([status])
  @@index([createdAt])
}

model ScenarioTechnology {
  scenarioId   String
  technologyId String

  scenario   Scenario   @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  technology Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@id([scenarioId, technologyId])
}

model Solution {
  id          String   @id @default(cuid())
  scenarioId  String
  authorId    String
  content     String
  codeSnippet String?
  language    String?
  isAccepted  Boolean  @default(false)
  upvotes     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scenario    Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes       Vote[]

  @@index([scenarioId])
  @@index([authorId])
}

model Vote {
  id        String   @id @default(cuid())
  userId    String
  value     Int      // +1 or -1
  createdAt DateTime @default(now())

  // Exactly one of these will be set
  scenarioId String?
  solutionId String?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenario Scenario? @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  solution Solution? @relation(fields: [solutionId], references: [id], onDelete: Cascade)

  @@unique([userId, scenarioId])
  @@unique([userId, solutionId])
  @@index([scenarioId])
  @@index([solutionId])
}
