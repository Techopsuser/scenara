generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  image         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  emailVerified DateTime?
  role          String     @default("user")
  passwordHash  String?
  accounts      Account[]
  scenarios     Scenario[]
  sessions      Session[]
  solutions     Solution[]
  votes         Vote[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Scenario {
  id           String               @id @default(cuid())
  title        String
  summary      String?
  content      String
  difficulty   String
  status       String               @default("draft")
  views        Int                  @default(0)
  authorId     String
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  author       User                 @relation(fields: [authorId], references: [id])
  technologies ScenarioTechnology[]
  solutions    Solution[]
  votes        Vote[]
}

model Technology {
  id        String               @id @default(cuid())
  name      String
  slug      String               @unique
  category  String?
  scenarios ScenarioTechnology[]
}

model ScenarioTechnology {
  scenarioId   String
  technologyId String
  scenario     Scenario   @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  technology   Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@id([scenarioId, technologyId])
}

model Solution {
  id         String   @id @default(cuid())
  scenarioId String
  authorId   String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     User     @relation(fields: [authorId], references: [id])
  scenario   Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
}

model Vote {
  id         String   @id @default(cuid())
  userId     String
  value      Int
  scenarioId String
  scenario   Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, scenarioId])
}
